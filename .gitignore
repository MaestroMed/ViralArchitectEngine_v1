# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
dist-electron/
release/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm
# Transpiled Electron main/preload sit alongside their .ts source — never commit.
apps/desktop/electron/*.js
apps/desktop/electron/*.d.ts
# TypeScript incremental build caches.
*.tsbuildinfo
# Lock files: this is a pnpm workspace — npm/yarn lockfiles cause double-install
# conflicts in CI.
package-lock.json
yarn.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
*.egg
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
ehthumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend_out.log
backend_err.log
backend.log

# Environment
.env
.env.local
.env.*.local

# Test coverage
coverage/
.nyc_output/

# Temp files
*.tmp
*.temp
.cache/

# SQLite databases
*.db
*.sqlite
*.sqlite3

# FFmpeg outputs (keep in gitignore)
*.mp4
*.mkv
*.avi
*.mov
*.webm

# Large media files
*.wav
*.mp3
*.aac
*.ogg

# Thumbnails
thumbnail.jpg
thumbnails/

# User data
FORGE_LIBRARY/

# Build resources (platform specific)
apps/desktop/resources/python/
apps/desktop/resources/python-*/
apps/desktop/resources/ffmpeg/
apps/desktop/resources/ffmpeg-*/
# TOFU checksum store written by scripts/prepare-python.js
apps/desktop/resources/.checksums.json

# Installer graphics (optional, user-provided)
# apps/desktop/build-resources/installer-header.bmp
# apps/desktop/build-resources/installer-sidebar.bmp
# apps/desktop/build-resources/dmg-background.png
